# -*- mode: ruby -*-
# vi: set ft=ruby :
#
# Vagrant demo environment for bayesian-ssh
# 3-VM setup: 1 bastion (+ Kerberos KDC) + 2 target servers
# Provider: libvirt/KVM
#
# Usage:
#   cd demo && vagrant up
#   bash test-all.sh
#   vagrant destroy -f

VAGRANTFILE_API_VERSION = "2"

# ── Network Layout ─────────────────────────────────────────────
BASTION_IP  = "192.168.56.10"
TARGET1_IP  = "192.168.56.11"
TARGET2_IP  = "192.168.56.12"
DOMAIN      = "bssh.test"
KRB_REALM   = "BSSH.TEST"

BOX         = "generic/ubuntu2204"

# ── Key Generation Trigger ─────────────────────────────────────
# Generate an Ed25519 keypair before first provision if missing.
# The keypair lives in demo/keys/ and is distributed to all VMs
# via the common.sh provisioner.

def ensure_keypair
  key_dir  = File.join(__dir__, "keys")
  key_file = File.join(key_dir, "id_ed25519")
  return if File.exist?(key_file)

  FileUtils.mkdir_p(key_dir)
  puts "🔑 Generating Ed25519 keypair in demo/keys/ ..."
  system("ssh-keygen -t ed25519 -f #{key_file} -N '' -C 'bssh-demo-key' -q")
  puts "   ✅ Keypair created"
end

ensure_keypair

Vagrant.configure(VAGRANTFILE_API_VERSION) do |config|
  config.vm.box = BOX

  # Disable default synced folder (we'll use /vagrant for script/key sharing)
  config.vm.synced_folder ".", "/vagrant", type: "rsync",
    rsync__exclude: [".vagrant/", "*.log"]

  # ── Bastion ────────────────────────────────────────────────
  config.vm.define "bastion", primary: true do |bastion|
    bastion.vm.hostname = "bastion.#{DOMAIN}"
    bastion.vm.network "private_network", ip: BASTION_IP

    bastion.vm.provider :libvirt do |lv|
      lv.memory = 1024
      lv.cpus   = 1
    end

    bastion.vm.provision "shell", path: "scripts/common.sh", args: [
      BASTION_IP, TARGET1_IP, TARGET2_IP, DOMAIN
    ]
    bastion.vm.provision "shell", path: "scripts/setup-kdc.sh", args: [
      BASTION_IP, TARGET1_IP, TARGET2_IP, DOMAIN, KRB_REALM
    ]
    bastion.vm.provision "shell", path: "scripts/setup-ssh.sh"
  end

  # ── Target 1 (primary) ────────────────────────────────────
  config.vm.define "target1" do |t1|
    t1.vm.hostname = "target1.#{DOMAIN}"
    t1.vm.network "private_network", ip: TARGET1_IP

    t1.vm.provider :libvirt do |lv|
      lv.memory = 1024
      lv.cpus   = 1
    end

    t1.vm.provision "shell", path: "scripts/common.sh", args: [
      BASTION_IP, TARGET1_IP, TARGET2_IP, DOMAIN
    ]
    t1.vm.provision "shell", path: "scripts/setup-krb-client.sh", args: [
      BASTION_IP, DOMAIN, KRB_REALM
    ]
    t1.vm.provision "shell", path: "scripts/setup-ssh.sh"
    t1.vm.provision "shell", path: "scripts/setup-services.sh"
  end

  # ── Target 2 (secondary) ──────────────────────────────────
  config.vm.define "target2" do |t2|
    t2.vm.hostname = "target2.#{DOMAIN}"
    t2.vm.network "private_network", ip: TARGET2_IP

    t2.vm.provider :libvirt do |lv|
      lv.memory = 1024
      lv.cpus   = 1
    end

    t2.vm.provision "shell", path: "scripts/common.sh", args: [
      BASTION_IP, TARGET1_IP, TARGET2_IP, DOMAIN
    ]
    t2.vm.provision "shell", path: "scripts/setup-krb-client.sh", args: [
      BASTION_IP, DOMAIN, KRB_REALM
    ]
    t2.vm.provision "shell", path: "scripts/setup-ssh.sh"
  end
end
